  "implementation": "step_1_sourcecandidate_pipeline",
  "project": "Geospatial AI Autoresearcher",
  "version": "v1",
  "goal": "Verify that the search/fetch stage reliably converts a research brief into a bounded, deduplicated set of SourceCandidate records with preserved provenance and usable fetched text.",
  "success_definition": {
    "overall_pass_condition": "All critical checks pass and at least 80% of non-critical checks pass.",
    "critical_checks": [
      "query_generation",
      "retrieval_execution",
      "sourcecandidate_schema_validity",
      "provenance_preservation",
      "deduplication",
      "bounded_output",
      "retrieved_text_presence"
    ]
  },
  "input_contract": {
    "required_input": {
      "research_brief": "string"
    },
    "example_input": {
      "research_brief": "Find frontier work relevant to 3D geospatial scene understanding and recommend the next CesiumJS-native experiments."
    }
  },
  "output_contract": {
    "type": "array",
    "item_type": "SourceCandidate",
    "min_items": 5,
    "max_items": 20,
    "required_fields": [
      "id",
      "query",
      "title",
      "url",
      "source_type",
      "publisher",
      "authors",
      "published_at",
      "search_snippet",
      "retrieved_text",
      "retrieval_method",
      "retrieval_timestamp",
      "confidence"
    ]
  },
  "checks": [
    {
      "id": "query_generation",
      "priority": "critical",
      "description": "System generates multiple search queries from the research brief.",
      "pass_condition": {
        "min_queries": 3,
        "max_queries": 6,
        "queries_nonempty": true,
        "queries_relevant_to_brief": true
      }
    },
    {
      "id": "retrieval_execution",
      "priority": "critical",
      "description": "System successfully runs supported retrieval methods.",
      "pass_condition": {
        "must_use_at_least_one_of": [
          "tavily",
          "arxiv"
        ],
        "successful_source_fetch_count_min": 5
      }
    },
    {
      "id": "sourcecandidate_schema_validity",
      "priority": "critical",
      "description": "Every returned item matches the SourceCandidate schema.",
      "pass_condition": {
        "all_items_have_required_fields": true,
        "field_types_valid": true,
        "confidence_range": [
          0.0,
          1.0
        ],
        "published_at_format": "YYYY-MM-DD or null",
        "retrieval_timestamp_format": "ISO-8601"
      }
    },
    {
      "id": "provenance_preservation",
      "priority": "critical",
      "description": "Raw discovery provenance is preserved for downstream extraction.",
      "pass_condition": {
        "all_items_have_query": true,
        "all_items_have_url": true,
        "all_items_have_search_snippet": true,
        "all_items_have_retrieval_method": true
      }
    },
    {
      "id": "retrieved_text_presence",
      "priority": "critical",
      "description": "Fetched text is present and usable for downstream extraction.",
      "pass_condition": {
        "min_items_with_nontrivial_retrieved_text": 5,
        "minimum_retrieved_text_chars_per_item": 300
      }
    },
    {
      "id": "deduplication",
      "priority": "critical",
      "description": "Exact and obvious duplicates are removed from the final set.",
      "pass_condition": {
        "duplicate_urls_in_final_output": 0,
        "duplicate_title_rate_max": 0.1
      }
    },
    {
      "id": "bounded_output",
      "priority": "critical",
      "description": "Final candidate set is bounded for downstream extraction.",
      "pass_condition": {
        "min_final_items": 5,
        "max_final_items": 20
      }
    },
    {
      "id": "source_type_quality",
      "priority": "noncritical",
      "description": "Source types are inferred plausibly.",
      "pass_condition": {
        "valid_source_type_rate_min": 0.9
      }
    },
    {
      "id": "metadata_completeness",
      "priority": "noncritical",
      "description": "Useful metadata is populated when available.",
      "pass_condition": {
        "publisher_present_rate_min": 0.8,
        "authors_present_rate_min": 0.4,
        "published_at_present_rate_min": 0.4
      }
    },
    {
      "id": "coverage_quality",
      "priority": "noncritical",
      "description": "Final set covers more than one relevant source category.",
      "pass_condition": {
        "distinct_source_types_min": 2,
        "includes_paper_or_repo": true
      }
    }
  ],
  "test_cases": [
    {
      "id": "geospatial_frontier_general",
      "brief": "Find frontier work relevant to 3D geospatial scene understanding and recommend the next CesiumJS-native experiments.",
      "expected_outcome": "Returns a mixed set of papers, repos, blogs, or demos relevant to 3D geospatial AI."
    },
    {
      "id": "viewpoint_reasoning",
      "brief": "Find work related to viewpoint selection, camera planning, and terrain-aware scene reasoning for geospatial 3D environments.",
      "expected_outcome": "Returns candidates related to camera/viewpoint reasoning, 3D scenes, terrain, or mapping."
    },
    {
      "id": "dataset_benchmark_focus",
      "brief": "Find datasets and benchmarks relevant to 3D geospatial AI, reconstruction, remote sensing, and scene understanding.",
      "expected_outcome": "Returns candidates with stronger dataset/benchmark presence and usable metadata."
    }
  ],
  "failure_conditions": [
    "No final SourceCandidate output returned.",
    "Fewer than 5 usable candidates returned.",
    "Any critical schema field missing from any final item.",
    "Final output dominated by duplicates.",
    "Retrieved text missing or too short for most items.",
    "Provenance fields omitted.",
    "Output not bounded."
  ],
  "evaluation_evidence": {
    "artifacts_to_capture": [
      "input research brief",
      "generated queries",
      "raw search results",
      "final SourceCandidate JSON output",
      "deduplication decisions",
      "validation report per item"
    ],
    "recommended_summary_metrics": [
      "query_count",
      "raw_result_count",
      "final_candidate_count",
      "nonempty_retrieved_text_count",
      "duplicate_url_count",
      "distinct_source_type_count",
      "schema_pass_rate"
    ]
  },
  "scoring": {
    "method": "weighted_checks",
    "weights": {
      "query_generation": 10,
      "retrieval_execution": 15,
      "sourcecandidate_schema_validity": 20,
      "provenance_preservation": 15,
      "retrieved_text_presence": 15,
      "deduplication": 10,
      "bounded_output": 10,
      "source_type_quality": 2.5,
      "metadata_completeness": 1.5,
      "coverage_quality": 1
    },
    "pass_threshold": 85
  }
}
